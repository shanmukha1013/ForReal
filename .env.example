# ForReal - example environment variables for production
# Copy this to .env (DO NOT commit secrets)

# MongoDB connection URI (use Atlas in production)
MONGO_URI=mongodb://username:password@host:27017/forreal

# JWT secret (use a strong random value)
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# Frontend client URL (production)
CLIENT_URL=https://your-frontend.example.com

# Server port
PORT=5000

# Node environment
NODE_ENV=production
